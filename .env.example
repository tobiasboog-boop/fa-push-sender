# ── FA App Database (VPS4) ──────────────────────────────────────────────────
# Verbinding met app_financiele_analyse schema (analyses, klant-configs, runs)
APP_DB_HOST=10.3.152.8
APP_DB_PORT=5532
APP_DB_NAME=notifica_app
APP_DB_USER=notifica_app
APP_DB_PASSWORD=VEREIST

# ── Notifica Data API ────────────────────────────────────────────────────────
# DWH-sleutel om SQL uit te voeren op klant-databases
# Vraag Mark om de DWH-key (NOTIFICA_DWH_KEY / NOTIFICA_DATA_KEY)
NOTIFICA_DATA_KEY=VEREIST

# Pad naar de notifica_sdk (lokale ontwikkeling; niet nodig op VPS als je de
# sdk als package installeert of naast de app zet)
NOTIFICA_SDK_PATH=c:\projects\notifica_app\apps\_sdk

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=VEREIST

# ── App-beveiliging ──────────────────────────────────────────────────────────
# Wachtwoord dat Arthur gebruikt om in te loggen in de Streamlit-app
APP_PASSWORD=kies-een-sterk-wachtwoord

# ── Resend (optioneel) ───────────────────────────────────────────────────────
# Wordt automatisch uit de FA app DB gelezen.
# Alleen invullen als fallback (DB-verbinding onbereikbaar).
# RESEND_API_KEY=re_...
