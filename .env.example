# ─────────────────────────────────────────────────────────────────────────────
# FA Push Sender — dunne client over Mark's financiele-analyse backend.
# Geen login-scherm: de app draait alleen binnen het Notifica-platform (de draft
# is afgeschermd voor ingelogde medewerkers) en authenticeert zichzelf met een
# vaste service-login. Alle zware logica (DWH, Claude, Resend) zit in de
# notifica-app op VPS4.
# ─────────────────────────────────────────────────────────────────────────────

# Notifica API (financiele-analyse endpoints). Default is goed voor productie.
NOTIFICA_API_URL=https://app.notifica.nl

# Supabase (auth). Zelfde project/anon-key als de React-apps.
SUPABASE_URL=https://db.notifica.nl
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVzeHN0ZG1lbGppY2xtY2JqZ3Z1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njk0Mjg0NTYsImV4cCI6MjA4NTAwNDQ1Nn0.OhtOSrpsxqJaWNvhYTGFnZNVQ1JsmOMObbDdYEWR07A

# Vaste service-sessie. De app gebruikt dit refresh-token om server-side een
# Supabase-JWT te halen (captcha-vrij) voor Mark's /api/fa endpoints.
# Ophalen: log in op app.notifica.nl, console:
#   JSON.parse(localStorage.getItem('notifica-auth')).refresh_token
# Refresh-tokens roteren lenient bij Notifica → een vast token blijft werken.
FA_REFRESH_TOKEN=VEREIST

# (Optioneel/fallback) wachtwoordlogin — werkt NIET zolang Supabase-captcha aan staat.
# FA_LOGIN_EMAIL=
# FA_LOGIN_PASSWORD=
